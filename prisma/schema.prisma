model Feature {
  id          Int           @id @default(autoincrement())
  key         String        @unique // Ключ фичи (например, "unlimited_search")
  name        String        // Человекочитаемое название
  description String?       // Описание фичи
  category    String?       // Категория (например, "search", "maps", "premium")
  isActive    Boolean       @default(true) // Включена ли фича в системе
  isPremium   Boolean       @default(false) // Премиум-фича?
  userFeatures UserFeature[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("features")
}

model UserFeature {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  featureId Int
  feature   Feature   @relation(fields: [featureId], references: [id])
  expiresAt DateTime? // Когда истекает доступ (null - бессрочно)
  isActive  Boolean   @default(true) // Активен ли доступ
  metadata  Json?     // Дополнительные метаданные о статусе фичи у пользователя
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, featureId])
  @@map("user_features")
}

